{
    "name": "docsort-pro-backend",
    "version": "1.0.0",
    "description": "DocSort Pro - PDF Document Management Backend",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "migrate": "npx knex migrate:latest",
        "migrate:rollback": "npx knex migrate:rollback",
        "migrate:status": "npx knex migrate:status",
        "migrate:make": "npx knex migrate:make",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.js\" --ignore-unknown"
    },
    "dependencies": {
        "@pdf-lib/fontkit": "^1.1.1",
        "archiver": "^7.0.1",
        "axios": "^1.13.5",
        "bcryptjs": "^2.4.3",
        "better-sqlite3": "^12.6.2",
        "canvas": "^3.1.0",
        "cors": "^2.8.5",
        "dotenv": "^16.6.1",
        "exceljs": "^4.4.0",
        "express": "^4.21.2",
        "form-data": "^4.0.5",
        "fs-extra": "^11.2.0",
        "heic-convert": "^2.1.0",
        "jsonwebtoken": "^9.0.2",
        "knex": "^3.1.0",
        "multer": "^1.4.5-lts.1",
        "mysql2": "^3.12.0",
        "node-unrar-js": "^2.0.2",
        "pdf-lib": "^1.17.1",
        "pdfjs-dist": "^3.11.174",
        "playwright": "^1.58.2",
        "sharp": "^0.34.5",
        "xlsx": "^0.18.5",
        "xlsx-populate": "^1.21.0"
    },
    "devDependencies": {
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "nodemon": "^3.1.9",
        "prettier": "^3.8.1"
    }
}
